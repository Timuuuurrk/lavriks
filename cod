@bot.message_handler(commands=['weather'])
def get_weather(message):
    buf=message.text.strip().lower()
    city=buf[8:]
    rek=requests.get(f'https://api.openweathermap.org/data/2.5/weather?q={city}&appid={wAPI}&units=metric&lang=ru')
    if rek.status_code!=200:
        bot.reply_to(message,'У меня не получилось найти город с таким названием(  Проверь, что ты правильно указал(а) данные о нём')
        return
    data=json.loads(rek.text)
    tempa=data["main"]["temp"]
    flik=data["main"]["feels_like"]
    s=str(rek.text)
    desc=''
    if s.find('пасмурно')!=-1:
        desc='пасмурно'
    elif s.find('ясно')!=-1:
        desc='ясно'
    elif s.find('облачно с прояснениями')!=-1:
        desc='облачно с прояснениями'
    elif s.find('небольшая облачность')!=-1:
        desc='небольшая облачность'
    elif s.find('переменная облачность')!=-1:
        desc='переменная облачность'
    elif s.find('небольшой дождь')!=-1:
        desc='небольшой дождь'
    elif s.find('небольшой снег')!=-1:
        desc='небольшой снег'
    kek=''
    if int(flik)<-20:
        kek='🥶'
    elif int(flik)<0:
        kek='🤧'
    elif int(flik)<10:
        kek='😇'
    else:
        kek='🥵'
    gorod=data["name"]
    bot.reply_to(message,f'Погода в {gorod}:\n\nТемпература:{tempa}°С\n\nОщущается как:{flik}°С{kek}\n\nХарактер погоды:{desc}')

